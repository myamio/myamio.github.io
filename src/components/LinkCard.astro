---
import Icon from './icons/Icon.astro';

interface Props {
	title: string;
	url: string | null;
	description: string;
	icon: string;
}

const { title, url, description, icon } = Astro.props;
const isLink = url !== null;
---

<div class="group relative block rounded-lg border border-gray-200 dark:border-gray-800 p-6 transition-all hover:border-black dark:hover:border-gray-400 hover:shadow-sm h-[120px] flex flex-col justify-center">
	{isLink ? (
		<a href={url} target="_blank" rel="noopener noreferrer" class="absolute inset-0">
			<span class="sr-only">{title}</span>
		</a>
	) : (
		<span class="absolute right-3 top-3 rounded-full bg-gray-100 dark:bg-gray-800 px-2 py-0.5 text-[10px] font-medium text-gray-600 dark:text-gray-400">
			Coming Soon
		</span>
	)}

	<div class="flex items-center space-x-4">
		<div class="flex-shrink-0 text-gray-700 dark:text-gray-400 group-hover:text-black dark:group-hover:text-white transition-colors">
			<Icon name={icon} />
		</div>
		<div class="flex-1 min-w-0">
			<h3 class="font-bold text-gray-900 dark:text-gray-100 truncate">{title}</h3>
			<p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed truncate">{description}</p>
		</div>
	</div>
</div>
