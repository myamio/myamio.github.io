---
import { getSiteData } from '../lib/data';

interface Props {
  rssUrl: string;
  icon: string;
}

const { rssUrl, icon } = Astro.props;
const { gist } = getSiteData();

// Generate a unique ID to avoid collisions when multiple components are rendered
const uniqueId = `rss-${crypto.randomUUID()}`;
---

<div id={uniqueId} class="mt-3 text-sm hidden relative z-10">
  <span class="text-xs font-semibold text-gray-500 uppercase tracking-widest mr-2 flex-shrink-0 mt-0.5">Latest</span>
  <a href="#" target="_blank" rel="noopener noreferrer" class="rss-link text-gray-700 hover:text-black hover:underline transition-colors break-words min-w-0 flex-1 leading-snug">
    <!-- Title will be injected here -->
  </a>
</div>

<script define:vars={{ icon, uniqueId, gistId: gist?.gistId, username: gist?.username }}>
  (async function() {
    if (!gistId || gistId === 'YOUR_GIST_ID') return;

    try {
      // Use cache-busting slightly by using the current hour (GitHub Gist cache is about 5 mins anyway)
      // We don't want to bust cache completely to avoid hitting raw.githubusercontent.com rate limits too fast
      // But we also want to eventually get fresh data.
      const date = new Date();
      const cacheBuster = `${date.getFullYear()}${date.getMonth()}${date.getDate()}${date.getHours()}`;
      const url = `https://gist.githubusercontent.com/${username}/${gistId}/raw/rss-feed.json?t=${cacheBuster}`;

      const response = await fetch(url);
      if (!response.ok) return;

      const data = await response.json();
      const latestItem = data[icon];

      if (!latestItem || !latestItem.link || !latestItem.title) return;

      const container = document.getElementById(uniqueId);
      const link = container?.querySelector('.rss-link');

      if (container && link) {
        link.href = latestItem.link;
        link.textContent = latestItem.title;
        container.classList.remove('hidden');
        container.classList.add('flex', 'items-start');
      }
    } catch (error) {
      // Fail silently as requested
      console.error('Failed to fetch RSS feed:', error);
    }
  })();
</script>
